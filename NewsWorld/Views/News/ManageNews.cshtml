@model X.PagedList.IPagedList<NewsWorld.Models.News>

@{
    ViewData["Title"] = "Manage News";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Manage News</h2>
            <p class="text-muted mb-0">View, update and delete all news articles</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-dark rounded-pill px-4">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <a asp-controller="News" asp-action="AddNews" class="btn btn-dark rounded-pill px-4">
                + Add News
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th width="180">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>

                                    <td>
                                        <img src="@item.ImagePath"
                                             width="90"
                                             height="60"
                                             class="rounded shadow-sm border"
                                             style="object-fit:cover;" />
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @item.Title
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-dark px-3 py-2">
                                            @item.Category?.CategoryName
                                        </span>
                                    </td>

                                    <td>
                                        <a asp-controller="News"
                                           asp-action="EditNews"
                                           asp-route-id="@item.Id"
                                           class="btn btn-primary btn-sm rounded-pill px-3">
                                            Edit
                                        </a>

                                        <a asp-controller="News"
                                           asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm rounded-pill px-3"
                                           onclick="return confirm('Are you sure you want to delete this news?')">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <div class="text-muted">No news found</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["newsSuccess"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: '@TempData["newsSuccess"]',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        </script>

        TempData.Remove("newsSuccess"); 
    }
}