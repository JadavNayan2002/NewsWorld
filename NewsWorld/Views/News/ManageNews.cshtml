@model X.PagedList.IPagedList<NewsWorld.Models.News>

@{
    ViewData["Title"] = "Manage News";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Manage News</h2>
            <p class="text-muted mb-0">View, update and delete all news articles</p>
        </div>

        <div class="d-flex gap-2">

            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-dark rounded-pill px-4">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <a asp-controller="News" asp-action="AddNews" class="btn btn-dark rounded-pill px-4">
                + Add News
            </a>
        
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>City</th>
                            <th width="100">Status</th>
                            <th width="200">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    @* <td>@item.Id</td> *@

                                    <td>
                                        <img src="@item.ImagePath"
                                             width="90"
                                             height="60"
                                             class="rounded shadow-sm border"
                                             style="object-fit:cover;" />
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @item.Title
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-dark px-3 py-2">
                                            @item.Category?.CategoryName
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-dark px-3 py-2">
                                            @item.City?.CityName
                                        </span>
                                    </td>

                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <div class="d-flex flex-column align-items-center gap-2">
                                                <span class="badge bg-success px-3 py-2 rounded-pill">Active</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column align-items-center gap-2">
                                                <span class="badge bg-secondary px-3 py-2 rounded-pill">
                                                    Inactive
                                                </span>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <!-- Edit Button -->
                                        <a asp-controller="News"
                                           asp-action="EditNews"
                                           asp-route-id="@item.Id"
                                           class="btn btn-primary btn-sm rounded-pill px-3">
                                            <i class="bi bi-pencil-square me-1"></i>
                                        </a>

                                        <!-- Delete Button -->
                                        <a asp-controller="News"
                                           asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm rounded-pill px-3"
                                           onclick="return confirm('Are you sure you want to delete this news?')">
                                            <i class="bi bi-trash3-fill me-1"></i>
                                        </a>

                                        @if (item.IsActive)
                                        {
                                            <a asp-controller="News"
                                               asp-action="ToggleStatus"
                                               asp-route-id="@item.Id"
                                               class="btn btn-success btn-sm rounded-pill">
                                                <i class="bi bi-toggle-on"></i>
                                                ON
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="News"
                                               asp-action="ToggleStatus"
                                               asp-route-id="@item.Id"
                                               class="btn btn-secondary btn-sm rounded-pill">
                                                <i class="bi bi-toggle-off"></i>
                                                OFF
                                            </a>
                                        }
                                        
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="text-muted">No news found</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <ul class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.PageCount; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">

                            <a class="page-link"
                               href="@Url.Action("ManageNews", "News", new { page = i })">
                                @i
                            </a>

                        </li>
                    }

                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["newsSuccess"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: '@TempData["newsSuccess"]',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        </script>

        TempData.Remove("newsSuccess");
    }
}