@model X.PagedList.IPagedList<Admin>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Admin Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">Admin Users</h2>
            <p class="text-muted mb-0">
                Manage administrator accounts
            </p>
        </div>

        <a asp-controller="Admin"
           asp-action="AddUser"
           class="btn btn-dark rounded-pill px-4">

            <i class="bi bi-person-plus"></i>
            Add Admin

        </a>

    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body">

            @if (Model.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-dark">

                            <tr>
                                <th>Username</th>
                                <th class="text-center">Actions</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var admin in Model)
                            {
                                <tr>

                                    <td>
                                        <span class="fw-semibold">
                                            @admin.Username
                                        </span>
                                    </td>

                                    <td class="text-center">

                                        <a asp-action="EditAdmin"
                                           asp-route-id="@admin.Id"
                                           class="btn btn-sm btn-warning rounded-pill px-4">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <form asp-action="DeleteAdmin"
                                            asp-controller="Admin"
                                            method="post"
                                            style="display:inline;">

                                            <input type="hidden" name="id" value="@admin.Id" />

                                            <button type="submit"
                                                class="btn btn-sm btn-danger rounded-pill px-4"
                                                onclick="return confirm('Are you sure you want to delete this admin?');">

                                            <i class="bi bi-trash"></i>

                                            </button>
                                        </form>
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                    <div class="d-flex justify-content-center mt-4">
                        @Html.PagedListPager(
                            Model,
                            page => Url.Action("Users", new { page }),
                            new PagedListRenderOptions
                            {
                                LiElementClasses = new[] { "page-item" },
                                PageClasses = new[] { "page-link" }
                            })
                    </div>

                </div>
            }
            else
            {
                <div class="text-center py-5">

                    <i class="bi bi-person-x display-3 text-muted"></i>

                    <h5 class="mt-3">
                        No Admin Users Found
                    </h5>

                    <p class="text-muted">
                        Create your first administrator account.
                    </p>

                </div>
            }

        </div>

    </div>

</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}