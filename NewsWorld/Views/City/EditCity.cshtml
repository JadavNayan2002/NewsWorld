@model NewsWorld.Models.City

@{
    ViewData["Title"] = "Edit City";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">

            <h3 class="fw-bold mb-4">Edit City</h3>

            <form asp-action="EditCity" method="post">

                <input type="hidden" asp-for="CityId" />

                <div class="mb-3">
                    <label class="form-label">City Name</label>

                    <input asp-for="CityName"
                           class="form-control rounded-pill" />

                    <span asp-validation-for="CityName"
                          class="text-danger"></span>
                </div>

                @* <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div> *@

                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    Update City
                </button>

                <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
                    Back
                </a>

            </form>

        </div>
    </div>
</div>