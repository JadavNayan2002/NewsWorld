@model X.PagedList.IPagedList<NewsWorld.Models.City>
@using X.PagedList.Mvc.Core
@using X.PagedList

@{
    ViewData["Title"] = "Manage City";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold display-5 mb-2">City Master</h1>

            <p class="text-muted fs-4">
                View, manage and remove Cities
            </p>
        </div>

        <a asp-controller="City"
           asp-action="CreateCity"
           class="btn btn-dark rounded-pill px-4 py-3 fw-semibold">

            <i class="bi bi-plus-lg me-2"></i>
            Add City

        </a>

    </div>

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table align-middle table-hover">

                    <thead class="table-dark">
                        <tr>
                            <th>City Name</th>
                            <th width="100">Status</th>
                            <th width="200">Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- City Name -->
                                    <td>
                                        <div class="fw-semibold">
                                            @item.CityName
                                        </div>
                                    </td>

                                    <!-- Status -->
                                    <td>

                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">
                                                Inactive
                                            </span>
                                        }

                                    </td>

                                    <!-- Actions -->
                                    <td class="d-flex gap-2">

                                        <!-- Edit -->
                                        <a asp-controller="City"
                                           asp-action="EditCity"
                                           asp-route-id="@item.CityId"
                                           class="btn btn-primary btn-sm rounded-pill px-3">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <!-- Delete -->
                                        <form asp-controller="City"
                                              asp-action="Delete"
                                              asp-route-id="@item.CityId"
                                              method="post">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm rounded-pill px-3"
                                                    onclick="return confirm('Are you sure you want to delete this city?')">

                                                <i class="bi bi-trash3-fill"></i>

                                            </button>

                                        </form>

                                        <!-- Toggle Status -->
                                        @if (item.IsActive)
                                        {
                                            <a asp-controller="City"
                                               asp-action="ToggleStatus"
                                               asp-route-id="@item.CityId"
                                               class="btn btn-success btn-sm rounded-pill">

                                                <i class="bi bi-toggle-on"></i>
                                                ON

                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="City"
                                               asp-action="ToggleStatus"
                                               asp-route-id="@item.CityId"
                                               class="btn btn-secondary btn-sm rounded-pill">

                                                <i class="bi bi-toggle-off"></i>
                                                OFF

                                            </a>
                                        }

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4">

                                    <div class="text-muted">
                                        No city found
                                    </div>

                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

                @* @Html.PagedListPager(
                    Model,
                    page => Url.Action("Index", new { page }),
                    new PagedListRenderOptions
                    {
                        UlElementClasses = new[] { "pagination" },
                        LiElementClasses = new[] { "page-item" },
                        PageClasses = new[] { "page-link" }
                    }
                ) *@
                <ul class="pagination justify-content-center">

                    @for (int i = 1; i <= Model.PageCount; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", "City", new { page = i })">
                                @i
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </div>

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

</div>