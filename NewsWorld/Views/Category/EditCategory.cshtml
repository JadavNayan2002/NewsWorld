@model NewsWorld.Models.Category

@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <!-- Heading -->
    <div class="mb-4">

        <h1 class="fw-bold display-6">
            Edit Category
        </h1>

        <p class="text-muted fs-5">
            Update category details
        </p>

    </div>

    <!-- Form Card -->
    <div class="card border-0 shadow-sm rounded-5 p-4">

        <form asp-action="EditCategory" method="post">

            <input type="hidden" asp-for="Id" />

            <!-- Category Name -->
            <div class="mb-4">

                <label asp-for="CategoryName"
                       class="form-label fw-semibold fs-5">
                    Category Name
                </label>

                <input asp-for="CategoryName"
                       class="form-control form-control-lg rounded-4"
                       placeholder="Enter category name" />

                <span asp-validation-for="CategoryName"
                      class="text-danger"></span>

            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3">

                <button type="submit"
                        class="btn btn-dark rounded-pill px-4 py-2">

                    <i class="bi bi-check-circle me-1"></i>
                    Update Category

                </button>

                <a asp-action="Category"
                   class="btn btn-outline-secondary rounded-pill px-4 py-2">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}