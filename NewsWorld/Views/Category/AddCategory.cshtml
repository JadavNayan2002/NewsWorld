@model NewsWorld.Models.Category

@{
    ViewData["Title"] = "Add Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 py-4">

    <!-- Heading -->
    <div class="mb-4">
        <h1 class="fw-bold display-6">
            Add Category
        </h1>
        <p class="text-muted fs-5">
            Create a new category for news articles
        </p>
    </div>

    <!-- Form Card -->
    <div class="card border-0 shadow-sm rounded-5 p-4">

        <form asp-controller="Category" asp-action="AddCategory" method="post">

            <!-- Category Name -->
            <div class="mb-4">

                <label asp-for="CategoryName"
                       class="form-label fw-semibold fs-5">
                    Category Name
                </label>

                <input asp-for="CategoryName"
                       class="form-control form-control-lg rounded-4"
                       placeholder="Enter category name" />

                <span asp-validation-for="CategoryName"
                      class="text-danger"></span>

            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3">

                <button type="submit"
                        class="btn btn-dark rounded-pill px-4 py-2">
                    <i class="bi bi-plus-circle me-1"></i>
                    Save Category
                </button>

                <a asp-controller="Category"
                   asp-action="Category"
                   class="btn btn-outline-secondary rounded-pill px-4 py-2">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}