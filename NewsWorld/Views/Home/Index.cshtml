@model IEnumerable<NewsWorld.Models.News>

@{
    ViewData["Title"] = "Latest News";
    Layout = "~/Views/Shared/_Layout.cshtml";
}    
    
    <!-- Hero -->
    <div class="bg-dark text-white rounded-4 p-5 mb-5 shadow-lg">
        <h1 class="display-5 fw-bold">
            Latest News Updates
        </h1>
        <p class="lead mb-0">
            Stay updated with trending news around the world
        </p>
    </div>

    <!-- News Grid -->
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden">

                    <!-- Image -->
                    <img src="@item.ImagePath"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;" />

                    <!-- Body -->
                    <div class="card-body d-flex flex-column">

                        <!-- Category -->
                        <div class="mb-2">

                            <span class="badge bg-dark px-3 py-2">
                                @item.Category
                            </span>

                        </div>

                        <!-- Title -->
                        <h4 class="fw-bold">

                            @item.Title

                        </h4>

                        <!-- Short Desc -->
                        <p class="text-muted flex-grow-1">

                            @item.SortDescription

                        </p>

                        <!-- Footer -->
                        <div class="d-flex justify-content-between align-items-center mt-3">

                            <small class="text-muted">
                                @item.CreatedDate.ToString("dd MMM yyyy")
                            </small>

                            <a asp-controller="Home"
                               asp-action="NewsDetails"
                               asp-route-id="@item.Id"
                               class="btn btn-dark rounded-pill px-4">

                                Read More

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

